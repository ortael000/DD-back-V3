{ "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "characterPassword", 
    "description": "Shema of data structure for the basic information needed to generate a character in battleScissor", 
    "type": "array", 
    "properties": { 
        "CharacterId": { 
            "description": "Unique identifier for the character", 
            "type": "integer",
            "primaryKey": true 
        },
        "Password": { 
            "description": "Password for the character", 
            "type": "string",
            "primaryKey": false 
        }
    }
}       